# Copy to .env.local for local dev, and set VITE_API_URL as a build-time
# environment variable in your GitHub Actions workflow / CI for production.

# Base URL of the deployed Express API (see /server). Must NOT have a
# trailing slash. GitHub Pages is static-only, so this must point at
# wherever you deploy /server separately (Render, Railway, Fly.io, a VPS...).
VITE_API_URL=http://localhost:4000
