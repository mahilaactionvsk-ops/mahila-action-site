# Copy this file to .env and fill in real values. Never commit .env.

# Port the API listens on
PORT=4000

# Comma-separated list of origins allowed to call this API
# (your GitHub Pages URL + local dev URL)
CORS_ORIGIN=https://username.github.io,http://localhost:5173

# Long random string used to sign admin session JWTs.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Path to the SQLite database file
DB_PATH=./data/mahila.db

# Set to "true" in production (GitHub Pages + this API are different origins,
# so the admin session cookie needs Secure + SameSite=None to work at all —
# this flag controls both). Keep "false" for local http://localhost dev.
COOKIE_SECURE=false

# Where the frontend is served — used to build links inside emails (e.g. the
# volunteer password reset link). Match this to VITE_API_URL's counterpart:
# your local Vite dev URL (usually http://localhost:5173) or your deployed
# GitHub Pages URL in production.
FRONTEND_URL=http://localhost:5173

# Optional: SMTP credentials for actually sending volunteer password-reset
# emails. If left unset, reset links are printed to this server's console
# instead of emailed — handy for local testing, not for production.
# Example values for Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587,
# SMTP_USER=your@gmail.com, SMTP_PASS=<a 16-character Gmail "app password",
# not your normal Gmail password — generate one at myaccount.google.com/apppasswords>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
